# Anthropic OAuth token from `claude setup-token`
ANTHROPIC_API_KEY=sk-ant-oat-...

# Resend API key from resend.com dashboard
RESEND_API_KEY=re_...

# Product Hunt API token (optional — if unset, PH collector is skipped)
